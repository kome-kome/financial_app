# ============================================================
# .env.example — 必要な環境変数の一覧
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env
# ============================================================

# --------------------------------------------------------
# [必須] EDINET API キー
# https://disclosure.edinet-fsa.go.jp/ でAPIキーを取得
# --------------------------------------------------------
EDINET_API_KEY=your_edinet_api_key_here

# --------------------------------------------------------
# [必須] PostgreSQL 接続 URL
# 書式: postgresql://ユーザー名:パスワード@ホスト:ポート/DB名
#
# 本番・推奨: Supabase (本プロジェクトのマスター DB)
#   postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT].supabase.co:5432/postgres?sslmode=require
#   Render 本番と同じ Supabase インスタンスを参照する。
#
# 開発互換: ローカル PostgreSQL（Phase 6 で廃止予定。docs/REFACTORING.md 参照）
#   postgresql://edinet:edinet@localhost:5432/financial_db
#
# 移行用: ローカル → Supabase 同期スクリプトを使う場合は両方の URL を併記して
# 環境変数を切替ながら使う。scripts/compare_db_counts.py 参照。
# --------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT].supabase.co:5432/postgres?sslmode=require

# 移行作業時にローカル DB の URL を保持しておくための任意キー
# scripts/compare_db_counts.py や scripts/migrate_local_to_supabase.py で参照
LOCAL_DATABASE_URL=postgresql://edinet:edinet@localhost:5432/financial_db

# --------------------------------------------------------
# [必須] アプリのログインパスワード
# 英数字・記号を混ぜた強力なパスワードを設定すること
# 例: python -c "import secrets; print(secrets.token_urlsafe(24))"
# --------------------------------------------------------
APP_PASSWORD=your_strong_password_here

# --------------------------------------------------------
# [必須] JWT署名用の秘密鍵
# 未設定の場合、起動時に Warning が出る（開発用デフォルト値が使われる）
# 本番環境では必ず設定すること
# 例: python -c "import secrets; print(secrets.token_hex(32))"
# --------------------------------------------------------
APP_SECRET_KEY=your_secret_key_here

# --------------------------------------------------------
# [推奨] パスワードリセット用の回復キー
# APP_PASSWORD を忘れた場合にリセットするために使用
# 設定しないとパスワードリセット機能が使えない
# --------------------------------------------------------
APP_RECOVERY_KEY=your_recovery_key_here

# --------------------------------------------------------
# [本番のみ必須] CORS 許可オリジン
# デフォルト: http://localhost:8000
# 外部サーバーにデプロイする場合は実際のドメインを設定
# 複数指定する場合はカンマ区切り: https://example.com,https://www.example.com
# --------------------------------------------------------
ALLOWED_ORIGIN=http://localhost:8000

# --------------------------------------------------------
# [任意] J-Quants API Key
# https://jpx-jquants.com/ にログイン後、「API Keys」ページから取得してここに貼る
# email/password より権限範囲が狭く、有効期限なし
# 無料プランで過去2年分の日次 OHLCV が取得可能
# --------------------------------------------------------
JQUANTS_API_KEY=your_api_key_here

# --------------------------------------------------------
# [Render のみ] ライト実行モード
# true で重い処理（全件収集等）をブロック。Render Free の OOM・502 対策。
# 本番は render.yaml で true 固定。ローカルでは未設定 / false でよい。
# --------------------------------------------------------
RENDER_LIGHT_MODE=false
